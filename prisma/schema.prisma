generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  TEAM
}

enum ProjectLanguage {
  en
  vi
  mixed
}

enum SourceType {
  reddit
  facebook_group
  forum
  app_review
  youtube
  csv
}

enum AnalysisStatus {
  pending
  fetching
  processing
  clustering
  generating
  completed
  failed
}

enum InsightCategory {
  pain_point
  feature_request
  complaint
  workaround
  buying_intent
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  plan      Plan      @default(FREE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects   Project[]
}

model Project {
  id           String        @id @default(cuid())
  userId       String
  name         String
  niche        String
  language     ProjectLanguage
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources      Source[]
  rawPosts     RawPost[]
  painPoints   PainPoint[]
  analysisRuns AnalysisRun[]
}

model Source {
  id         String     @id @default(cuid())
  projectId  String
  type       SourceType
  configJson Json
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model RawPost {
  id           String        @id @default(cuid())
  projectId    String
  sourceType   SourceType
  sourcePostId String
  title        String?
  content      String
  author       String?
  url          String?
  publishedAt  DateTime?
  metadataJson Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments     RawComment[]
  evidences    PainEvidence[]

  @@unique([projectId, sourcePostId])
  @@index([projectId, sourceType])
}

model RawComment {
  id           String        @id @default(cuid())
  rawPostId    String
  sourceType   SourceType
  sourcePostId String?
  content      String
  author       String?
  publishedAt  DateTime?
  metadataJson Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  rawPost      RawPost       @relation(fields: [rawPostId], references: [id], onDelete: Cascade)
  evidences    PainEvidence[]

  @@index([rawPostId])
}

model PainPoint {
  id              String           @id @default(cuid())
  projectId       String
  title           String
  description     String
  category        InsightCategory
  urgencyScore    Int
  frequencyScore  Int
  commercialScore Int
  totalScore      Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evidences       PainEvidence[]
  suggestions     IdeaSuggestion[]

  @@index([projectId, totalScore])
}

model PainEvidence {
  id           String      @id @default(cuid())
  painPointId  String
  rawPostId    String?
  rawCommentId String?
  excerpt      String
  sentiment    Int
  confidence   Float
  createdAt    DateTime    @default(now())
  painPoint    PainPoint   @relation(fields: [painPointId], references: [id], onDelete: Cascade)
  rawPost      RawPost?    @relation(fields: [rawPostId], references: [id], onDelete: SetNull)
  rawComment   RawComment? @relation(fields: [rawCommentId], references: [id], onDelete: SetNull)

  @@index([painPointId])
}

model IdeaSuggestion {
  id              String    @id @default(cuid())
  painPointId     String
  title           String
  description     String
  businessModel   String
  mvpFeaturesJson Json
  difficulty      String
  monetization    String
  audience        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  painPoint       PainPoint @relation(fields: [painPointId], references: [id], onDelete: Cascade)

  @@index([painPointId])
}

model AnalysisRun {
  id              String         @id @default(cuid())
  projectId       String
  status          AnalysisStatus @default(pending)
  filtersJson     Json?
  startedAt       DateTime       @default(now())
  finishedAt      DateTime?
  totalDocuments  Int            @default(0)
  totalPainPoints Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}
